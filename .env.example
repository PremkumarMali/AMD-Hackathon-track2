# Copy this file to `.env` and fill in your own values locally.
# The real `.env` is git-ignored and must NEVER be committed.

# Your Fireworks AI API key (from https://fireworks.ai). Leave blank to stay
# on the offline mock caption generator.
FIREWORKS_API_KEY=

# Vision model id (call 1 — describes the frames). Must be accessible to your
# Fireworks account (confirm the id in your dashboard).
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p6

# Text model id (call 2 — formats the 4 captions as JSON). Must be a chat model
# accessible to your account.
FIREWORKS_TEXT_MODEL=accounts/fireworks/models/gpt-oss-120b

# Set to 1 to use Fireworks AI. Any other value (or unset) uses mock captions.
USE_FIREWORKS=0
